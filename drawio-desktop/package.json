{
  "name": "trellis-for-drawio",
  "productName": "Trellis Studio",
  "version": "2.3.2",
  "drawioBaseVersion": "29.0.3",
  "description": "Trellis Studio desktop",
  "exports": "./src/main/electron.js",
  "type": "module",
  "main": "src/main/electron.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "test": "npm run test:plugins && npm run test:icons",
    "test:plugins": "node --test ./test/created-change-map-history.test.cjs ./test/garden-scheduler-dialog.test.cjs ./test/planting-scheduler-reliability.test.cjs ./test/task-manager-overlays.test.cjs ./test/sowing-season-diagnostics.test.cjs ./test/year-planner.test.cjs ./test/year-planner-dom.test.cjs ./test/trellis-context-menu.test.cjs ./test/trellis-updates-links.test.cjs ./test/trellis-splash-backgrounds.test.mjs ./test/tidy-context-menu.test.cjs ./test/modules-standalone.test.cjs ./test/garden-beds.test.cjs ./test/garden-equipment.test.cjs ./test/garden-irrigation-planner.test.cjs ./test/garden-dashboard-toolbar.test.cjs ./test/bed-succession-navigator.test.cjs ./test/deep-click-through.test.cjs ./test/plant-tiler-overlay.test.cjs ./test/fold-control-renderer.test.cjs ./test/splash-dialog.test.cjs ./test/file-watch-registry.test.mjs ./test/release-prepare.test.mjs ./test/electron-builder-config.test.cjs ./test/updater-progress.test.cjs ./test/bundled-update-menu.test.cjs",
    "test:task-manager": "node --test ./test/task-manager-overlays.test.cjs ./test/planting-scheduler-reliability.test.cjs ./test/trellis-overlay-layering.test.cjs",
    "test:release-prepare": "node --test ./test/release-prepare.test.mjs",
    "start": "electron .",
    "sync": "node ./sync.cjs",
    "trellis:seed": "python ./scripts/trellis_seed_cli.py",
    "trellis:seed:sowing-season-diagnostics": "node ./scripts/trellis_seed_sowing_season_diagnostics.cjs",
    "assets:icons": "python ./scripts/generate_app_icons.py",
    "assets:icons:check": "python ./scripts/generate_app_icons.py --check",
    "test:icons": "node --test ./test/icon-assets.test.cjs",
    "test:trellis-seed": "python -m unittest discover -s ./test/trellis_seed -p \"test_*.py\"",
    "release:prepare": "node ./scripts/release-prepare.mjs",
    "test:year-planner": "node --test ./test/year-planner.test.cjs ./test/year-planner-dom.test.cjs",
    "test:year-planner:model": "node --test ./test/year-planner.test.cjs",
    "test:year-planner:dom": "node --test ./test/year-planner-dom.test.cjs",
    "release-win": "electron-builder --config electron-builder-win.json --publish always",
    "release-win32": "electron-builder --config electron-builder-win32.json --publish always",
    "release-win-arm64": "electron-builder --config electron-builder-win-arm64.json --publish always",
    "release-appx": "electron-builder --config electron-builder-appx.json --publish always",
    "release-linux": "electron-builder --config electron-builder-linux-mac.json --publish always",
    "release-mac": "electron-builder --mac --config electron-builder-linux-mac.json --publish always",
    "release-mac-x64": "electron-builder --mac --config electron-builder-mac-x64.json --publish always",
    "release-mac-arm64": "electron-builder --mac --config electron-builder-mac-arm64.json --publish always",
    "release-snap": "electron-builder --config electron-builder-snap.json --publish never"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Benjamin-Elon/Trellis-for-Drawio.git"
  },
  "keywords": [
    "draw.io",
    "diagram",
    "flowchart",
    "UML"
  ],
  "author": "Benjamin Elon",
  "license": "SEE LICENSE IN LICENSES.md",
  "bugs": {
    "url": "https://github.com/Benjamin-Elon/Trellis-for-Drawio/issues"
  },
  "homepage": "https://github.com/Benjamin-Elon/Trellis-for-Drawio",
  "dependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@cantoo/pdf-lib": "^2.5.3",
    "better-sqlite3": "^12.5.0",
    "clipboardy": "^5.1.0",
    "commander": "^13.1.0",
    "compression": "^1.8.1",
    "crc": "^4.3.2",
    "electron-context-menu": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-progressbar": "^2.2.1",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.8",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@electron/notarize": "^3.1.0",
    "dotenv": "^16.6.1",
    "electron": "^38.7.0",
    "electron-builder": "^26.0.20",
    "jsdom": "^26.1.0",
    "sumchecker": "^3.0.1"
  }
}
