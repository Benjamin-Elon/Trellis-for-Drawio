{
  "name": "trellis-for-drawio",
  "productName": "Trellis for Drawio",
  "version": "1.0.0",
  "drawioBaseVersion": "29.0.3",
  "description": "Trellis for Drawio desktop",
  "exports": "./src/main/electron.js",
  "type": "module",
  "main": "src/main/electron.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run test:plugins",
    "test:plugins": "node --test ./test/planting-scheduler-reliability.test.cjs ./test/year-planner.test.cjs ./test/year-planner-dom.test.cjs ./test/trellis-context-menu.test.cjs ./test/tidy-context-menu.test.cjs ./test/garden-beds.test.cjs ./test/bed-succession-navigator.test.cjs",
    "start": "electron .",
    "sync": "node ./sync.cjs",
    "test:year-planner": "node --test ./test/year-planner.test.cjs ./test/year-planner-dom.test.cjs",
    "test:year-planner:model": "node --test ./test/year-planner.test.cjs",
    "test:year-planner:dom": "node --test ./test/year-planner-dom.test.cjs",
    "release-win": "electron-builder --config electron-builder-win.json --publish always",
    "release-win32": "electron-builder --config electron-builder-win32.json --publish always",
    "release-win-arm64": "electron-builder --config electron-builder-win-arm64.json --publish always",
    "release-appx": "electron-builder --config electron-builder-appx.json --publish always",
    "release-linux": "electron-builder --config electron-builder-linux-mac.json --publish always",
    "release-mac": "electron-builder --mac --config electron-builder-linux-mac.json --publish always",
    "release-snap": "electron-builder --config electron-builder-snap.json --publish never"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Benjamin-Elon/Trellis-for-Drawio.git"
  },
  "keywords": [
    "draw.io",
    "diagram",
    "flowchart",
    "UML"
  ],
  "author": "Benjamin Elon",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Benjamin-Elon/Trellis-for-Drawio/issues"
  },
  "homepage": "https://github.com/Benjamin-Elon/Trellis-for-Drawio",
  "dependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@cantoo/pdf-lib": "^2.5.3",
    "better-sqlite3": "^12.5.0",
    "clipboardy": "^5.1.0",
    "commander": "^13.1.0",
    "compression": "^1.8.1",
    "crc": "^4.3.2",
    "electron-context-menu": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-progressbar": "^2.2.1",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.8",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@electron/notarize": "^3.1.0",
    "dotenv": "^16.6.1",
    "electron": "^38.7.0",
    "electron-builder": "^26.0.20",
    "jsdom": "^26.1.0",
    "sumchecker": "^3.0.1"
  },
  "directories": {
    "doc": "doc"
  }
}
